diff --git a/lib/html-encoding-sniffer.js b/lib/html-encoding-sniffer.js
index 0000000000000000000000000000000000000001..0000000000000000000000000000000000000002 100644
--- a/lib/html-encoding-sniffer.js
+++ b/lib/html-encoding-sniffer.js
@@ -1,2 +1,19 @@
 "use strict";
-const { getBOMEncoding, labelToName } = require("@exodus/bytes/encoding-lite.js");
+// Patched for Node 18 CJS compat: @exodus/bytes is ESM-only, inline the two needed fns
+function getBOMEncoding(u8) {
+  if (u8.length >= 3 && u8[0] === 0xef && u8[1] === 0xbb && u8[2] === 0xbf) return "UTF-8";
+  if (u8.length < 2) return null;
+  if (u8[0] === 0xff && u8[1] === 0xfe) return "UTF-16LE";
+  if (u8[0] === 0xfe && u8[1] === 0xff) return "UTF-16BE";
+  return null;
+}
+const LABEL_MAP = {
+  "utf-8":"UTF-8","utf8":"UTF-8","unicode-1-1-utf-8":"UTF-8",
+  "utf-16le":"UTF-16LE","utf-16":"UTF-16LE","utf-16be":"UTF-16BE",
+  "windows-1252":"windows-1252","iso-8859-1":"windows-1252","latin1":"windows-1252",
+};
+function labelToName(label) {
+  if (!label) return null;
+  const n = String(label).trim().toLowerCase();
+  return LABEL_MAP[n] || null;
+}
